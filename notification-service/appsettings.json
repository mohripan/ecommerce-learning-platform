{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "NotificationService": "Information"
    }
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "GroupId": "notification-service",
    "Topics": [
      "order-events",
      "inventory-events"
    ],
    "DeadLetterTopic": "notification-dlq"
  },
  "Smtp": {
    "Host": "localhost",
    "Port": 587,
    "UserName": "",
    "Password": "",
    "FromAddress": "noreply@ecommerce.local",
    "FromName": "Ecommerce Platform"
  },
  "Webhooks": {
    "MaxRetries": 3,
    "TimeoutSeconds": 10
  },
  "Otel": {
    "Endpoint": "http://localhost:4317"
  }
}
