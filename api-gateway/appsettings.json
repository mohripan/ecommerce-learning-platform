{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.RateLimiting": "Information"
    }
  },
  "AllowedHosts": "*",

  "Jwt": {
    "Authority": "https://identity.example.com",
    "Audience": "api-gateway",
    "RequireHttpsMetadata": true,
    "ValidateIssuer": true,
    "ValidateAudience": true,
    "ValidateLifetime": true,
    "ClockSkewSeconds": 30
  },

  "DownstreamServices": {
    "OrderService": {
      "BaseUrl": "http://order-service:8080",
      "TimeoutSeconds": 30,
      "RetryCount": 3,
      "CircuitBreakerFailureRatio": 0.5,
      "CircuitBreakerSamplingDurationSeconds": 10,
      "CircuitBreakerMinimumThroughput": 5,
      "CircuitBreakerBreakDurationSeconds": 30
    },
    "InventoryService": {
      "BaseUrl": "http://inventory-service:8080",
      "TimeoutSeconds": 15,
      "RetryCount": 3,
      "CircuitBreakerFailureRatio": 0.5,
      "CircuitBreakerSamplingDurationSeconds": 10,
      "CircuitBreakerMinimumThroughput": 5,
      "CircuitBreakerBreakDurationSeconds": 30
    }
  },

  "RateLimiting": {
    "GlobalPolicy": {
      "PermitLimit": 500,
      "WindowSeconds": 60,
      "QueueLimit": 50
    },
    "AuthenticatedPolicy": {
      "PermitLimit": 1000,
      "WindowSeconds": 60,
      "QueueLimit": 100
    },
    "OrdersPolicy": {
      "PermitLimit": 200,
      "WindowSeconds": 60,
      "QueueLimit": 20
    },
    "InventoryPolicy": {
      "PermitLimit": 300,
      "WindowSeconds": 60,
      "QueueLimit": 30
    }
  },

  "OpenTelemetry": {
    "ServiceName": "api-gateway",
    "ServiceVersion": "1.0.0",
    "OtlpEndpoint": "http://otel-collector:4317",
    "EnableConsoleExporter": false
  },

  "HealthChecks": {
    "OrderServiceUrl": "http://order-service:8080/health",
    "InventoryServiceUrl": "http://inventory-service:8080/health"
  }
}
