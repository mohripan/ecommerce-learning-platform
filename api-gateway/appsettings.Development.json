{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.AspNetCore.RateLimiting": "Debug"
    }
  },

  "Jwt": {
    "Authority": "https://localhost:5001",
    "Audience": "api-gateway",
    "RequireHttpsMetadata": false,
    "ValidateIssuer": false,
    "ValidateAudience": false,
    "ValidateLifetime": true,
    "ClockSkewSeconds": 300
  },

  "DownstreamServices": {
    "OrderService": {
      "BaseUrl": "http://localhost:5101",
      "TimeoutSeconds": 60,
      "RetryCount": 1,
      "CircuitBreakerFailureRatio": 0.8,
      "CircuitBreakerSamplingDurationSeconds": 30,
      "CircuitBreakerMinimumThroughput": 3,
      "CircuitBreakerBreakDurationSeconds": 10
    },
    "InventoryService": {
      "BaseUrl": "http://localhost:5102",
      "TimeoutSeconds": 60,
      "RetryCount": 1,
      "CircuitBreakerFailureRatio": 0.8,
      "CircuitBreakerSamplingDurationSeconds": 30,
      "CircuitBreakerMinimumThroughput": 3,
      "CircuitBreakerBreakDurationSeconds": 10
    }
  },

  "RateLimiting": {
    "GlobalPolicy": {
      "PermitLimit": 5000,
      "WindowSeconds": 60,
      "QueueLimit": 500
    },
    "AuthenticatedPolicy": {
      "PermitLimit": 10000,
      "WindowSeconds": 60,
      "QueueLimit": 1000
    },
    "OrdersPolicy": {
      "PermitLimit": 2000,
      "WindowSeconds": 60,
      "QueueLimit": 200
    },
    "InventoryPolicy": {
      "PermitLimit": 3000,
      "WindowSeconds": 60,
      "QueueLimit": 300
    }
  },

  "OpenTelemetry": {
    "ServiceName": "api-gateway-dev",
    "ServiceVersion": "1.0.0-dev",
    "OtlpEndpoint": "http://localhost:4317",
    "EnableConsoleExporter": true
  },

  "HealthChecks": {
    "OrderServiceUrl": "http://localhost:5101/health",
    "InventoryServiceUrl": "http://localhost:5102/health"
  }
}
