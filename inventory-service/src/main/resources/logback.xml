<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] [%X{traceId:-},%X{spanId:-}] %-5level %logger{40} — %msg%n</pattern>
    </encoder>
  </appender>

  <root level="INFO">
    <appender-ref ref="STDOUT"/>
  </root>

  <logger name="com.ecommerce.inventory"          level="DEBUG"/>
  <logger name="akka"                             level="INFO"/>
  <logger name="akka.cluster"                     level="INFO"/>
  <logger name="akka.persistence"                 level="INFO"/>
  <logger name="akka.http"                        level="INFO"/>
  <logger name="org.apache.kafka"                 level="WARN"/>
  <logger name="com.zaxxer.hikari"                level="WARN"/>
  <logger name="slick"                            level="WARN"/>

</configuration>
